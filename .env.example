# LLM Providers (at least one required)
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACEHUB_API_TOKEN=

# Search (Tavily - sign up at https://tavily.com for free tier)
TAVILY_API_KEY=

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.0-flash
FAST_LLM_MODEL=gemini-2.0-flash
STRONG_LLM_MODEL=gemini-2.5-flash

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_PREFIX=research_

# Cache
CACHE_DB_PATH=./data/cache.db
CACHE_SEARCH_TTL_HOURS=24
CACHE_SCRAPE_TTL_HOURS=168

# Rate Limits
SEARCH_MAX_PER_MINUTE=10
SCRAPE_CONCURRENCY=10
SCRAPE_TIMEOUT_SECONDS=15

# Report Output
REPORTS_DIR=./reports
